{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/stock.js", "use": "@vercel/node" },
    { "src": "api/ai.js", "use": "@vercel/node" },
    { "src": "api/fundamentals.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/stock", "dest": "/api/stock.js" },
    { "src": "/api/ai", "dest": "/api/ai.js" },
    { "src": "/api/fundamentals", "dest": "/api/fundamentals.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
